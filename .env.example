DATABASE_URL="postgresql://postgres:password@localhost:5432/clipscash?schema=public"

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Stellar payment listener ──────────────────────────────────────────────────
# Horizon server (use mainnet URL for production)
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# ClipCash platform account that receives subscription payments
STELLAR_RECEIVER_ADDRESS=

# Asset to accept: XLM (native) or a custom asset code + issuer
STELLAR_ASSET_CODE=XLM
STELLAR_ASSET_ISSUER=

# Polling fallback interval in milliseconds (used if SSE stream fails)
STELLAR_POLL_INTERVAL_MS=10000

# Subscription plan amounts (in asset units)
STELLAR_PLAN_BASIC_AMOUNT=5
STELLAR_PLAN_PRO_AMOUNT=15
STELLAR_PLAN_ELITE_AMOUNT=30

# ── NFT / Royalty config ──────────────────────────────────────────────────────
# Basis points: 100 bps = 1%
CREATOR_ROYALTY_BPS=1000
PLATFORM_ROYALTY_BPS=100
PLATFORM_WALLET_ADDRESS=

# Stellar Soroban RPC (for NFT minting)
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK=testnet
